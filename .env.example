# Web 控制台监听配置
HOST=0.0.0.0
PORT=8000
ADMIN_PASSWORD=your_admin_password_here
# 远程 Turnstile Solver 节点（必填，逗号分隔多个）
SOLVER_NODES=https://your-solver-1.example.com,https://your-solver-2.example.com

# 远程 Solver 调度 / 生命周期治理配置
# 生产必填：必须与远程 Solver 端的 SOLVER_ADMIN_TOKEN 完全一致，否则注册端无法执行 resume / heartbeat / drain / reinitialize 管理动作
SOLVER_ADMIN_TOKEN=change_me_shared_secret

# 定向软初始化（达到阈值后自动触发远程自愈）
SOLVER_REINIT_ENABLED=true
SOLVER_REINIT_TRIGGER_STREAK=2
SOLVER_REINIT_COOLDOWN_SECONDS=120
SOLVER_REINIT_REQUEST_TIMEOUT=20
SOLVER_REINIT_MAX_TARGETS=2
SOLVER_REINIT_ALLOW_BROADCAST=false
SOLVER_REINIT_REQUESTED_BY=register-cluster

# 生命周期治理（批次启动时 resume + heartbeat；批次结束或手动停止时 drain）
SOLVER_DRAIN_ON_BATCH_FINISH=true
SOLVER_DRAIN_GRACE_SECONDS=20
SOLVER_HEARTBEAT_INTERVAL_SECONDS=25
SOLVER_LEASE_TTL_SECONDS=90
SOLVER_CONTROL_POLL_INTERVAL_SECONDS=0.75

# im-mail / mail.tm 配置
IM_MAIL_API_BASE=http://your-im-mail-server-ip:port
IM_MAIL_AUTH_TOKEN=your_secure_auth_token_here
IM_MAIL_DOMAIN=example.com
MAILTM_API_BASE=https://api.mail.tm
MAILTM_WAIT_TIMEOUT=180

# 代理池配置
ENABLE_PROXY_POOL=false
PROXY_MODE=api_pool
PROXY_POOL_API_BASE=http://your-proxy-pool-server-ip:port

# sing-box 配置（按需启用）
SINGBOX_ENABLED=false
SINGBOX_PROXY=socks5://your-singbox-proxy-ip:port

# 其它运行时配置
DISABLE_SYSTEM_PROXY=true
